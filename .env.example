# ---------------------------------------------------------------
# LOCAL DEVELOPMENT (SQLite)
# schema: prisma/schema.dev.prisma  (provider = "sqlite")
# Commands:
#   npx prisma migrate dev --schema=prisma/schema.dev.prisma
#   npx prisma studio --schema=prisma/schema.dev.prisma
# ---------------------------------------------------------------
DATABASE_URL="file:./dev.db"
BASE_URL="http://localhost:3000"

# Email — nodemailer Titan SMTP (set real values in .env / Render env vars)
SMTP_HOST=smtp.titan.email
SMTP_PORT=587
SMTP_USER=info@h2aqua.com.mx
SMTP_PASS=tu_contraseña_de_aplicacion

# ---------------------------------------------------------------
# PRODUCTION — Supabase (PostgreSQL)
# schema: prisma/schema.prisma  (provider = "postgresql")
# Set these as environment variables in the Render dashboard,
# NOT in this file.
# Commands (deploy only, no new migration files):
#   npx prisma migrate deploy
# ---------------------------------------------------------------
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
# BASE_URL="https://h2aqua-backend.onrender.com"

# ---------------------------------------------------------------
# CLIP (payment gateway)
# Set these in Render dashboard (production)
# ---------------------------------------------------------------
# CLIP_API_KEY=your-clip-api-key
# CLIP_SECRET_KEY=your-clip-secret-key
# CLIP_MODE=production
# FRONTEND_URL=https://h2aqua.com.mx
